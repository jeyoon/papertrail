generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  notes     String?
  createdAt DateTime @default(now())

  drops  Drop[]
  visits Visit[]
}

model Event {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  description String?
  landingUrl  String
  createdAt   DateTime @default(now())

  flyers Flyer[]
}

model Design {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  flyers Flyer[]
}

model Flyer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId  String
  event    Event  @relation(fields: [eventId], references: [id])
  designId String
  design   Design @relation(fields: [designId], references: [id])

  printOrders PrintOrder[]
  drops       Drop[]

  @@unique([eventId, designId])
}

model PrintOrder {
  id        String   @id @default(cuid())
  quantity  Int
  orderedAt DateTime @default(now())
  notes     String?

  flyerId String
  flyer   Flyer  @relation(fields: [flyerId], references: [id])
}

model Drop {
  id        String   @id @default(cuid())
  qrCode    String?
  createdAt DateTime @default(now())

  flyerId    String
  flyer      Flyer    @relation(fields: [flyerId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  engagements     Engagement[]
  dropoffAttempts DropoffAttempt[]

  @@unique([flyerId, locationId])
}

model Engagement {
  id        String   @id @default(cuid())
  scannedAt DateTime @default(now())

  dropId String
  drop   Drop   @relation(fields: [dropId], references: [id])
}

model Visit {
  id        String   @id @default(cuid())
  visitedBy String
  visitedAt DateTime @default(now())
  notes     String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  dropoffAttempts DropoffAttempt[]
}

model DropoffAttempt {
  id       String        @id @default(cuid())
  quantity Int?
  status   DropoffStatus
  comment  String?

  visitId String
  visit   Visit  @relation(fields: [visitId], references: [id])
  dropId  String
  drop    Drop   @relation(fields: [dropId], references: [id])
}

enum DropoffStatus {
  accepted
  rejected
  tentative
}
